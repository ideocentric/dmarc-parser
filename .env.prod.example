# Production environment template — copy to .env.prod and fill in all required values.
# Usage: docker compose -f docker-compose.prod.yml up -d
#
# Fields marked REQUIRED must be set before the application will start.
# NEVER commit .env.prod to version control — it is gitignored.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# REQUIRED — any long random string used to sign JWTs.
# Generate: openssl rand -hex 32
SECRET_KEY=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# These three vars are read by the postgres container on first init.
# Keep them in sync with DATABASE_URL below.
POSTGRES_DB=dmarc
POSTGRES_USER=dmarc
# REQUIRED — generate a strong password: openssl rand -hex 24
POSTGRES_PASSWORD=

# SQLAlchemy connection URL for the API and watcher containers.
# Must match POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above.
DATABASE_URL=postgresql+psycopg2://dmarc:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/dmarc

# ── Report storage ────────────────────────────────────────────────────────────
REPORTS_BASE_DIR=/app/data/reports
ARCHIVE_RETENTION_DAYS=7

# ── Credential encryption ─────────────────────────────────────────────────────
# REQUIRED — Fernet symmetric key used to encrypt stored IMAP passwords / OAuth secrets.
# Generate: docker run --rm python:3.13-slim python -c \
#   "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── GeoIP ─────────────────────────────────────────────────────────────────────
GEOIP_DB_PATH=/app/geoip/GeoLite2-City.mmdb

# ── ClamAV ────────────────────────────────────────────────────────────────────
# Use the Docker service name "clamav" — defined in docker-compose.prod.yml.
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
# fail-closed: reject the file if clamd is unreachable (recommended for compliance)
CLAMAV_FAIL_OPEN=false

# ── Azure SSO (leave blank to disable) ───────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Set to your public domain after DNS and SSL are configured
AZURE_REDIRECT_URI=https://YOUR_DOMAIN/auth/callback
AZURE_AUTO_PROVISION=false

# ── MFA ───────────────────────────────────────────────────────────────────────
# Recommended true for production — forces all local accounts to enrol in TOTP.
MFA_REQUIRED=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Set to your public HTTPS domain
CORS_ORIGINS=https://YOUR_DOMAIN

# ── Seed data (used only on first startup — ignored on subsequent starts) ──────
ADMIN_EMAIL=admin@example.com
# REQUIRED — set a strong initial password (you will be prompted to change it)
ADMIN_PASSWORD=
TEST_CLIENT_SLUG=
TEST_CLIENT_NAME=