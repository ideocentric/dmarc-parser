# Docker environment template — copy to .env.docker and fill in all required values.
# Usage: docker compose --env-file .env.docker up --build -d
#
# Fields marked REQUIRED must be set before the application will start.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=testing
LOG_LEVEL=INFO

# REQUIRED — any long random string used to sign JWTs.
# Generate: openssl rand -hex 32
SECRET_KEY=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://dmarc:dmarc_dev@db:5432/dmarc

# ── Report storage ────────────────────────────────────────────────────────────
REPORTS_BASE_DIR=/app/data/reports
ARCHIVE_RETENTION_DAYS=7

# ── Credential encryption ─────────────────────────────────────────────────────
# REQUIRED — Fernet symmetric key used to encrypt stored IMAP passwords / OAuth secrets.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Must be a valid 32-byte URL-safe base64 string (the command above produces the correct format).
ENCRYPTION_KEY=

# ── GeoIP ─────────────────────────────────────────────────────────────────────
GEOIP_DB_PATH=/app/geoip/GeoLite2-City.mmdb

# ── Azure SSO (leave blank to disable) ───────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:5010/auth/callback
# Set to true to automatically create accounts for Azure users on first login.
# When false (default), unknown Azure users receive a 403 and must be created manually.
AZURE_AUTO_PROVISION=false

# ── MFA ───────────────────────────────────────────────────────────────────────
# When true, all local accounts must enrol in TOTP MFA before accessing the platform.
# Users without MFA set up will be redirected to the setup page on login.
# Only a super_admin can reset a user's MFA device (e.g. on lost device).
MFA_REQUIRED=false

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5010

# ── Seed data (used only on first startup) ────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# REQUIRED — set a strong password for the initial admin account.
ADMIN_PASSWORD=
TEST_CLIENT_SLUG=test-client
TEST_CLIENT_NAME="Test Client"