# Local development environment template — copy to .env and fill in all required values.
# Never commit .env to source control.
#
# Fields marked REQUIRED must be set before the application will start.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# REQUIRED — any long random string used to sign JWTs.
# Generate: openssl rand -hex 32
SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, local dev):
DATABASE_URL=sqlite:///data/dmarc.db
# PostgreSQL (production / Docker):
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/dmarc

# ── Report storage ────────────────────────────────────────────────────────────
REPORTS_BASE_DIR=data/reports
ARCHIVE_RETENTION_DAYS=7

# ── Credential encryption ─────────────────────────────────────────────────────
# REQUIRED — Fernet symmetric key used to encrypt stored IMAP passwords / OAuth secrets.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Must be a valid 32-byte URL-safe base64 string (the command above produces the correct format).
ENCRYPTION_KEY=

# ── GeoIP ─────────────────────────────────────────────────────────────────────
# Download GeoLite2-City.mmdb from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEOIP_DB_PATH=data/GeoLite2-City.mmdb

# ── Azure SSO (leave blank to disable) ───────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:5173/auth/callback
# Set to true to automatically create accounts for Azure users on first login.
# When false (default), unknown Azure users receive a 403 and must be created manually.
AZURE_AUTO_PROVISION=false

# ── ClamAV antivirus scanning (optional) ─────────────────────────────────────
# When enabled, every ingested file (file-drop and IMAP) is scanned by clamd
# before decompression. Requires a running clamd daemon and python-clamd.
# See docs/deployment-guide.md for ClamAV setup instructions.
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# CLAMAV_FAIL_OPEN=false means: reject the file if clamd is unreachable (safe default).
# Set to true only if report continuity is more important than security posture.
CLAMAV_FAIL_OPEN=false

# ── MFA ───────────────────────────────────────────────────────────────────────
# When true, all local accounts must enrol in TOTP MFA before accessing the platform.
# Users without MFA set up will be redirected to the setup page on login.
# Only a super_admin can reset a user's MFA device (e.g. on lost device).
MFA_REQUIRED=false

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173