# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it (contains your admin IP and DB password).

# ── Identity ─────────────────────────────────────────────────────────────────
project_name = "dmarc"
environment  = "prod"

# ── Region ───────────────────────────────────────────────────────────────────
aws_region = "us-east-1"

# ── Topology ──────────────────────────────────────────────────────────────────
# standalone    — App + DB run together on one EC2 in Docker Compose (simplest)
# split_vm      — App EC2 in public subnet, PostgreSQL EC2 in private subnet
# split_managed — App EC2 in public subnet, RDS PostgreSQL in private subnet (managed)
deployment_mode = "standalone"

# ── ClamAV ────────────────────────────────────────────────────────────────────
clamav_enabled = true

# ── Instance sizing ───────────────────────────────────────────────────────────
# instance_type = "t3.large"   # uncomment to override auto-selection
root_disk_gb = 100

# ── Access control ────────────────────────────────────────────────────────────
# Find your IP: curl -s https://checkip.amazonaws.com
admin_cidr = "YOUR_PUBLIC_IP/32"
# cicd_cidr  = null

# ── SSH key pair ──────────────────────────────────────────────────────────────
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# ── Container registry ────────────────────────────────────────────────────────
image_retention_count = 10
create_ci_user        = false

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidr    = "10.0.1.0/24"

# Required for split_vm and split_managed — ignored for standalone:
private_subnet_cidr   = "10.0.2.0/24"   # primary private subnet (DB VM or RDS)
private_subnet_cidr_2 = "10.0.3.0/24"   # second AZ (required for RDS subnet group)

# ── Database (required for split_vm and split_managed) ───────────────────────
# Generate a strong password: openssl rand -hex 24
# db_password = ""

# split_vm DB EC2 sizing:
# db_instance_type = "t3.small"
# db_disk_gb       = 30

# split_managed RDS sizing:
# db_instance_class      = "db.t3.micro"
# db_storage_gb          = 20
# db_backup_retention_days = 7
# db_deletion_protection   = false   # set true for production