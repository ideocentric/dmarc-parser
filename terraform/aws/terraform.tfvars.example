# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it (contains your admin IP).

# ── Identity ────────────────────────────────────────────────────────────────
project_name = "dmarc"
environment  = "prod"       # prod | staging | dev

# ── Region ──────────────────────────────────────────────────────────────────
aws_region = "us-east-1"

# ── Topology ─────────────────────────────────────────────────────────────────
deployment_mode = "standalone"   # standalone | split_vm | split_managed

# ── ClamAV ───────────────────────────────────────────────────────────────────
# When true, instance type auto-selects t3.large (8 GB RAM) to accommodate
# the ClamAV daemon's ~700 MB–1 GB virus signature footprint.
clamav_enabled = true

# ── Instance sizing ───────────────────────────────────────────────────────────
# Leave commented out to use the automatic selection driven by clamav_enabled.
# Uncomment to override:
# instance_type = "t3.large"
root_disk_gb = 100

# ── Access control ────────────────────────────────────────────────────────────
# Your public IP in CIDR notation — SSH (port 22) is restricted to this address.
# Find your IP: curl -s https://checkip.amazonaws.com
admin_cidr = "YOUR_PUBLIC_IP/32"

# CI/CD SSH access — optional second SSH rule.
# Self-hosted runner: set to your runner's fixed egress IP (e.g. "10.0.0.5/32")
# GitHub-hosted runners: set to "0.0.0.0/0" (any IP) — less secure, consider SSM instead
# Leave null (default) if deploying manually or using SSM for CI/CD.
# cicd_cidr = null

# ── SSH key pair ──────────────────────────────────────────────────────────────
# Path to your LOCAL public key file. Terraform uploads the public key to AWS
# under the name {project}-{environment}-keypair. The private key never leaves
# your machine — you use it to SSH: ssh -i ~/.ssh/id_rsa ubuntu@<public_ip>
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# ── Container registry ────────────────────────────────────────────────────────
image_retention_count = 10

# CI/CD IAM user — set true to create an IAM user with ECR push + SSM permissions.
# The access key and secret are output by terraform (store them as GitHub secrets).
# Leave false if using GitHub Actions OIDC (recommended — no long-lived credentials).
create_ci_user = false

# ── Networking ───────────────────────────────────────────────────────────────
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# Defaults to the first available AZ in the region. Override if needed:
# availability_zone = "us-east-1a"