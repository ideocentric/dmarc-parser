# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# ── Identity ─────────────────────────────────────────────────────────────────
project_name = "dmarc"
environment  = "prod"

# ── Azure ─────────────────────────────────────────────────────────────────────
# az account show --query id -o tsv
subscription_id = "YOUR_SUBSCRIPTION_ID"
location        = "East US"

# ── Topology ──────────────────────────────────────────────────────────────────
# standalone    — App + DB run together on one VM in Docker Compose (simplest)
# split_vm      — App VM in public subnet, PostgreSQL VM in private subnet
# split_managed — App VM in public subnet, Azure PostgreSQL Flexible Server
deployment_mode = "standalone"

# ── ClamAV ────────────────────────────────────────────────────────────────────
clamav_enabled = true

# ── VM sizing ─────────────────────────────────────────────────────────────────
# vm_size      = "Standard_B2ms"   # uncomment to override auto-selection
root_disk_gb   = 100
admin_username = "ubuntu"

# ── Access control ────────────────────────────────────────────────────────────
admin_cidr = "YOUR_PUBLIC_IP/32"
# cicd_cidr  = null

# ── SSH key pair ──────────────────────────────────────────────────────────────
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# ── Networking ────────────────────────────────────────────────────────────────
vnet_cidr          = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# Required for split_vm and split_managed — ignored for standalone:
private_subnet_cidr = "10.0.2.0/24"   # private subnet for DB VM
db_subnet_cidr      = "10.0.3.0/24"   # delegated subnet for PostgreSQL Flexible Server

# ── Database (required for split_vm and split_managed) ────────────────────────
# Generate a strong password: openssl rand -hex 24
# db_password = ""

# split_vm DB VM sizing:
# db_vm_size = "Standard_B2s"
# db_disk_gb = 30

# split_managed PostgreSQL Flexible Server:
# db_sku_name              = "B_Standard_B1ms"
# db_storage_mb            = 32768    # 32 GB minimum
# db_backup_retention_days = 7